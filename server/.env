# Must match db/.env (user/password/db) and use `db` as host inside the compose network.
DATABASE_URL=postgresql+psycopg://root:password123@localhost:5432/postgres

JWT_SECRET=please-change-me-to-a-32-plus-char-secret-value
JWT_ALG=HS256
JWT_EXPIRES_MIN=10080

COOKIE_SAMESITE=lax
COOKIE_SECURE=false

CORS_ORIGINS=http://localhost:5173
